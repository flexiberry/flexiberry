{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Berry",
  "scopeName": "source.berry",
  "fileTypes": ["berry", "be"],
  "patterns": [
    { "include": "#surroundingPairs" },
    { "include": "#comments" },
    { "include": "#task-definition" },
    { "include": "#api-definitions" },
    { "include": "#scalar-types" },
    { "include": "#keyvalue-pairs" },
    { "include": "#variables-definitions" },
    { "include": "#step-definitions" },
    { "include": "#operators" }
  ],
  "repository": {
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.berry",
          "match": "[+\\-*/%]|\\*\\*"
        },
        {
          "name": "keyword.operator.comparison.berry",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.berry",
          "match": "!|&&|\\|\\||Or|OR|AND|And"
        },
        {
          "name": "keyword.operator.assignment.berry",
          "match": "[+\\-*/%]?="
        },
        {
          "name": "keyword.operator.bitwise.berry",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.misc.berry",
          "match": "\\?|:|\\.{2,3}|=>"
        }
      ]
    },
    "task-definition": {
      "patterns": [
        {
          "name": "keyword.task",
          "match": "^Task\\s+(.+)$",
          "captures": {
            "1": { "name": "task.title" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-hash.berry",
          "match": "^##.*$"
        }
      ]
    },

    "surroundingPairs": {
      "patterns": [
        {
          "name": "meta.interpolation",
          "match": "(\\{\\{)([^}]*)(\\}\\})",

          "captures": {
            "1": { "name": "keyword.interpolation-open" },
            "2": { "name": "variable.other.interpolation" },
            "3": { "name": "keyword.interpolation-close" }
          }
        }
      ]
    },
    "keyvalue-pairs": {
      "patterns": [
        {
          "name": "meta.keyvalue.header",
          "match": "^\\s*(Header|Check|Capture|Params)\\s*",
          "captures": {
            "1": { "name": "keyword.keyvalue.header" }
          }
        },
        {
          "name": "meta.keyvalue-pairs",
          "match": "^\\s*(-)\\s*(['\"a-zA-Z\\-]*)\\s*(:)\\s*(?:\\s*(.*))?$",
          "captures": {
            "1": { "name": "keyvalue-pairs.hash" },
            "2": { "name": "keyvalue-pairs.key" },
            "3": { "name": "keyvalue-pairs.separator" },
            "4": { "name": "keyvalue-pairs.value" }
          }
        }
      ]
    },
    "scalar-types": {
      "patterns": [
        {
          "name": "meta.scalar.singlequote",
          "begin": "'|\"",
          "beginCaptures": {
            "0": { "name": "scalar.start" }
          },
          "end": "'|\"",
          "endCaptures": {
            "0": { "name": "scalar.end" }
          },
          "patterns": [
            {
              "name": "scalar.content",
              "match": "[^('|\")]+"
            }
          ]
        },
        {
          "name": "meta.scalar.multiline",
          "begin": "`",
          "beginCaptures": {
            "0": { "name": "scalar.multiline.start" }
          },
          "end": "`",
          "endCaptures": {
            "0": { "name": "scalar.multiline.end" }
          },
          "patterns": [
            {
              "name": "scalar.multiline.content",
              "match": "[^`]+"
            }
          ]
        }
      ]
    },
    "api-definitions": {
      "patterns": [
        {
          "name": "meta.api",
          "match": "^\\s*(Api)(?:\\s+(GET|POST|PUT|DELETE|PATCH))?\\s+((#)(\\S+))(?:\\s+(.*))?$",
          "captures": {
            "1": { "name": "keyword.api" },
            "2": { "name": "keyword.api.method" },
            "4": { "name": "api.identifier" },
            "5": { "name": "api.identifier" },
            "6": { "name": "api.title" }
          }
        },
        {
          "name": "meta.api.url",
          "match": "^(Url)\\s+(.+)$",
          "captures": {
            "1": { "name": "keyword.url" },
            "2": { "name": "string.url" }
          }
        },
        {
          "name": "meta.api.body",
          "match": "^\\s*(Body)\\s(\\w+)\\s*",
          "captures": {
            "1": { "name": "keyword.api.body" },
            "2": { "name": "type.api.body" }
          }
        },
        {
          "name": "meta.api.header",
          "match": "^\\s*(Header)\\s*",
          "captures": {
            "1": { "name": "keyword.api.header" }
          }
        }
      ]
    },
    "step-definitions": {
      "patterns": [
        {
          "name": "meta.step",
          "match": "^\\s*(Step)\\s+(Call|CALL)?\\s+(\\S+)\\s*(\\S+)(?:\\s+(.*))?$",
          "captures": {
            "1": { "name": "keyword.step" },
            "2": { "name": "keyword.step.action" },
            "3": { "name": "step.function" },
            "4": { "name": "step.function.name" },
            "5": { "name": "step.title" }
          }
        }
      ]
    },
    "variables-definitions": {
      "patterns": [
        {
          "name": "meta.variables",
          "match": "^\\s*(Var)(?:\\s+(@\\w+))?\\s+(.*)",
          "captures": {
            "1": { "name": "keyword.variable" },
            "2": { "name": "variable.pointer" },
            "3": { "name": "variable.name" }
          }
        }
      ]
    }
  },
  "firstLineMatch": "^#!.*\\bberry\\b"
}
