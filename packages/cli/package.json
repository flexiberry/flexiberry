{
  "name": "@flexiberry/cli",
  "version": "0.1.3",
  "description": "The official CLI shell for the FlexiBerry API Testing Framework, enabling keyboard-driven interactive creation, parsing, validation, and execution of Berry DSL scripts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "flexiberry": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "installglobal": "npm i -g .",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "flexiberry",
    "cli",
    "api-testing",
    "berry",
    "api-client",
    "rest-api",
    "test-automation",
    "interactive-cli",
    "dsl",
    "task-runner",
    "ci-cd",
    "openapi-parser",
    "swagger-importer",
    "curl-parser",
    "terminal-ui"
  ],
  "author": "Rintu Raj C <rinturajc@gmail.com>",
  "license": "MIT",
  "homepage": "https://flexiberry.dev",
  "bugs": {
    "url": "https://github.com/flexiberry/flexiberry/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flexiberry/flexiberry.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@flexiberry/berrycore": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}