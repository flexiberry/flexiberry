{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Berry Language Support",
      "configurations": ["Run Extension"],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Run Extension Tests",
      "configurations": ["Extension Tests"]
    }
  ],
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/flexiberry/packages/berry-language-support",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/berry-language-support/dist/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/packages/berry-language-support/**",
        "!**/node_modules/**"
      ],
      "cwd": "${workspaceFolder}/packages/berry-language-support"
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/flexiberry/packages/berry-language-support",
        "--extensionTestsPath=${workspaceFolder}/flexiberry/packages/berry-language-support/out/test",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/berry-language-support/out/test/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/packages/berry-language-support/**",
        "!**/node_modules/**"
      ],
      "cwd": "${workspaceFolder}/packages/berry-language-support"
    },
    {
      "name": "Attach to Extension Host",
      "type": "node",
      "request": "attach",
      "port": 6009,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/packages/berry-language-support/**",
        "!**/node_modules/**"
      ],
      "cwd": "${workspaceFolder}/flexiberry/packages/berry-language-support"
    }
  ]
}
