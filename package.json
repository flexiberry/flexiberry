{
  "name": "flexiberry",
  "version": "1.0.0",
  "description": "Flexiberry is an API testing framework designed to create test suites for various use cases, including functional testing, load testing, security testing, API data comparison, API response validation, API unit testing, and end-to-end testing",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "runui": "cd ./apps/ui && npm run dev ",
    "cli": "cd ./packages/berrycore && npm run start:cli ",
    "buildcore": "cd ./packages/berrycore && npm run build "
  },
  "keywords": [
    "flexiberry",
    "API",
    "API TESTING",
    "API quality Assurance ",
    "QA",
    "load tesing",
    "functional testing",
    "end to end tesing",
    "data comparison",
    "data validation",
    "end-to-end testing"
  ],
  "author": "rinturajc@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
