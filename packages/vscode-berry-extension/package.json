{
  "name": "vscode-berry-extension",
  "version": "1.0.2",
  "description": "",
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package",
    "test": "pnpm run compile && node ./out/extension.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "vscode": ">=1.50.0"
  },
  "activationEvents": [
    "onLanguage:berry"
  ],
  "contributes": {
    "languages": [
      {
        "id": "berry",
        "aliases": [
          "Berry",
          "berry"
        ],
        "extensions": [
          ".berry"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "berry",
        "scopeName": "source.berry",
        "path": "./syntaxes/berry.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Berry Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/berry-color-theme.json"
      }
    ],
    "configuration": {
      "title": "Berry Formatting",
      "properties": {
        "berry.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Berry formatting"
        },
        "berry.format.enableFormatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable format on save for Berry files"
        }
      }
    }
  },
  "dependencies": {
    "@flexiberry/berrycore": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "@types/vscode": "^1.50.0"
  }
}
