{
  "name": "Berry Theme",
  "type": "dark",
  "colors": {
    "editor.background": "#1E1E1E",
    "editor.foreground": "#D4D4D4",
    "editor.lineHighlightBackground": "#2A2D2E",
    "editor.selectionBackground": "#264F78",
    "editorCursor.foreground": "#A6A6A6",
    "editorWhitespace.foreground": "#404040"
  },
  "tokenColors": [
    // Task definitions
    {
      "scope": "keyword.task",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "task.title",
      "settings": {
        "foreground": "#999999",
        "fontStyle": ""
      }
    },

    // Step definitions
    {
      "scope": "keyword.step",
      "settings": {
        "foreground": "#cba6f7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyword.step.action",
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": "step.function",
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "scope": "step.function.name",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "step.title",
      "settings": {
        "foreground": "#cdd6f4"
      }
    },

    // Operators
    {
      "scope": "keyword.operator.arithmetic.berry",
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": "keyword.operator.comparison.berry",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "keyword.operator.logical.berry",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "keyword.operator.assignment.berry",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "keyword.operator.bitwise.berry",
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "scope": "keyword.operator.misc.berry",
      "settings": {
        "foreground": "#a6e3a1"
      }
    },

    // Comments
    {
      "scope": ["comment.line.double-hash.berry"],
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },
    // Interpolation
    {
      "scope": ["keyword.interpolation-open", "keyword.interpolation-close"],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": ["variable.other.interpolation"],
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": ""
      }
    },

    // VAR definitions
    {
      "scope": ["keyword.variable", "variable.pointer", "variable.name"],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "keyword.variable",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "variable.pointer",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": ""
      }
    },
    {
      "scope": "variable.name",
      "settings": {
        "foreground": "#999999",
        "fontStyle": ""
      }
    },
    // API Definitions
    {
      "scope": [
        "keyword.api",
        "keyword.api.method",
        "api.identifier",
        "api.title"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "keyword.api",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "keyword.api.method",
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "api.identifier",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": ""
      }
    },
    {
      "scope": "api.title",
      "settings": {
        "foreground": "#999999",
        "fontStyle": ""
      }
    },

    // URLs
    {
      "scope": "api.identifier",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": ""
      }
    },
    {
      "scope": "keyword.url",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "string.url",
      "settings": {
        "foreground": "#78ca70",
        "fontStyle": "italic bold underline"
      }
    },
    {
      "scope": "keyword.api.body",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "type.api.body",
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": "keyword.api.header",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "scalar.multiline.start",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "scalar.multiline.content",
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "scalar.multiline.end",
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "keyvalue-pairs.hash",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": "keyvalue-pairs.key",
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": "keyvalue-pairs.separator",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "scalar.start",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "scalar.end",
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "scalar.content",
      "settings": {
        "foreground": "#ffb86c",
        "fontStyle": "italic"
      }
    },

    {
      "scope": "keyvalue-pairs.value",
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "scope": "meta.keyvalue.header",
      "settings": {
        "foreground": "#cba6f7"
      }
    }
  ]
}
