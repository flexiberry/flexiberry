{
  "name": "vscode-berry-extension",
  "displayName": "FlexiBerry",
  "publisher": "flexiberry",
  "version": "1.0.4",
  "description": "Interactive developer extension for the FlexiBerry DSL. Write, validate, and execute API test scripts with real-time visual feedback.",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0f121a",
    "theme": "dark"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing"
  ],
  "keywords": [
    "berry",
    "api",
    "testing",
    "rest",
    "assertion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flexiberry/flexiberry"
  },
  "homepage": "https://flexiberry.dev",
  "bugs": {
    "url": "https://github.com/flexiberry/flexiberry/issues"
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "build": "pnpm run compile",
    "package": "vsce package",
    "test": "pnpm run compile && node ./out/extension.js"
  },
  "author": "FlexiBerry Team",
  "license": "MIT",
  "engines": {
    "vscode": ">=1.50.0"
  },
  "activationEvents": [
    "onLanguage:berry",
    "onCommand:berry.runFile",
    "onCommand:berry.runApiAlone"
  ],
  "contributes": {
    "languages": [
      {
        "id": "berry",
        "aliases": [
          "Berry",
          "berry"
        ],
        "extensions": [
          ".berry"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "berry",
        "scopeName": "source.berry",
        "path": "./syntaxes/berry.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Berry Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/berry-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "berry.runFile",
        "title": "Run Berry File",
        "category": "Berry",
        "icon": "$(play)"
      },
      {
        "command": "berry.runApiAlone",
        "title": "Run API Standalone",
        "category": "Berry"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "berry.runFile",
          "when": "resourceLangId == berry",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "berry.runFile",
          "when": "resourceLangId == berry",
          "group": "1_run"
        }
      ]
    },
    "configuration": {
      "title": "Berry Formatting",
      "properties": {
        "berry.format.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Berry formatting"
        },
        "berry.format.enableFormatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable format on save for Berry files"
        }
      }
    }
  },
  "dependencies": {
    "@flexiberry/berrycore": "workspace:*",
    "@flexiberry/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "@types/vscode": "^1.50.0"
  }
}