{
  "name": "flexiberry",
  "version": "1.0.0",
  "description": "Flexiberry is an API testing framework designed to create test suites for various use cases, including functional testing, load testing, security testing, API data comparison, API response validation, API unit testing, and end-to-end testing",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "runui": "cd ./apps/ui && pnpm run dev ",
    "watch": "cd ./packages/berrycore && pnpm run watch ",
    "buildcore": "cd ./packages/berrycore && pnpm run build ",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "build:all": "node scripts/build-all.js",
    "dev:all": "node scripts/run-all.js",
    "build:app": "pnpm --filter ui build",
    "build:doc": "pnpm --filter documentation build",
    "build:website": "pnpm --filter website build",
    "build:apps": "pnpm run build:app && pnpm run build:doc && pnpm run build:website",
    "dev:app": "pnpm --filter ui dev",
    "dev:doc": "pnpm --filter documentation dev",
    "dev:website": "pnpm --filter website dev"
  },
  "keywords": [
    "flexiberry",
    "API",
    "API TESTING",
    "API quality Assurance ",
    "QA",
    "load tesing",
    "functional testing",
    "end to end tesing",
    "data comparison",
    "data validation",
    "end-to-end testing"
  ],
  "author": "rinturajc@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}