{
  "name": "@flexiberry/cli",
  "version": "1.0.0",
  "description": "CLI package for FlexiBerry — zero third-party dependency shell",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "flexiberry": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "installglobal": "npm i -g ."
  },
  "keywords": ["flexiberry", "cli", "api-testing", "berry"],
  "author": "rintu raj c",
  "license": "MIT",
  "dependencies": {
    "@flexiberry/berrycore": "workspace:*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}